# ─────────────────────────────────────────────────────────────
# El System 环境变量
# 复制本文件为 .env.local（本地）或在 Vercel 项目设置里逐项配置。
# 真实的 key 不要提交进仓库。
# ─────────────────────────────────────────────────────────────

# Claude API 中转站（/api/chat、/api/cron/generate-status）
CLAUDE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_BASE_URL=https://jeniya.chat/v1
# 模型名。中转站若不认 claude-sonnet-4-6，改成它支持的名字（可选，默认 claude-sonnet-4-6）
CLAUDE_MODEL=claude-sonnet-4-6

# Notion 集成 token（所有 /api/notion/* 与状态读写）
# 在 https://www.notion.so/my-integrations 创建 internal integration 获取
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion：每日总结数据库（/api/status、/api/chat 记忆、cron 写入）
# 注意：这里要填「数据库 id」（数据库页 URL 里那串），不是数据源/collection id。
NOTION_DAILY_DB=ceaf7e01-8fa3-4143-b27a-276c58791dd9

# Notion：主记忆页 / 人物档案（/api/notion/memory，也注入聊天上下文）
NOTION_MEMORY_PAGE=375aaed0-c8b3-81be-880a-da4f41a6b826

# Notion：长期记忆页（注入聊天上下文）
NOTION_LONGTERM_PAGE=379aaed0-c8b3-8183-b631-c15e144315ad

# Notion：时间线页（/api/notion/timeline）
NOTION_TIMELINE_PAGE=375aaed0-c8b3-81d3-80e9-e19567c771c9

# Notion：愿望墙页（/api/notion/wishlist）
NOTION_WISHLIST_PAGE=375aaed0-c8b3-8139-a18e-fbad13ee27bf

# 天气（/api/status）
OPENWEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CITY=Hangzhou

# Web Push 推送（/api/push/*）
# 用 `npx web-push generate-vapid-keys` 生成一对，填进来
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# 云存档（对话跨设备同步、重装不丢）——可选
# 在 Vercel → Storage → 建一个 Upstash Redis 并连到项目，会自动注入下面这对变量。
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Notion：小家父页（让 El 按需读取里面任意子页）
NOTION_HOME_PAGE=37baaed0-c8b3-817d-b192-d53078801295

# Cron 保护密钥（可选）。设了之后只有带这个密钥的请求能触发 /api/cron/*（Vercel cron 会自动带）。
CRON_SECRET=
