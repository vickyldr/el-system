# el 地理感官 · 守望者配置（复制成 .env，别提交真实值）
# 隐私：HOME 坐标和你的 Apple ID 只留在这台机器，别进 git、别外发。

# —— 必填 ——
ICLOUD_APPLE_ID=you@example.com
GEO_POST_URL=https://你的域名/api/geo-event
CRON_SECRET=和小家_Vercel_上同一个值

# —— 首次登录用（走一遍 2FA + trust 后可删；之后走系统钥匙串免密续登）——
# ICLOUD_PASSWORD=你的Apple密码
#
# ⚠️ 无屏幕的 VPS 上：系统钥匙串多半用不了，所以这里**留着** ICLOUD_PASSWORD 别删，
#    并把 .env 权限锁死（chmod 600 .env）。守望者会用它续登，信任 cookie 存在磁盘上免再要 2FA。

# —— 家的坐标（不填则不触发出门/到家事件，只发当下快照 + 在外周期）——
# 怎么拿：地图上长按你家 → 复制经纬度（纬度在前、经度在后）
# HOME_LAT=30.2741
# HOME_LON=120.1551
# HOME_RADIUS_M=150         # 离家多少米算"出门"

# —— 可选微调 ——
# ICLOUD_DEVICE_NAME=       # 多台设备时指定哪台 iPhone（填名字的一部分）
# ICLOUD_CHINA=             # 中国大陆 Apple ID 填 1（用 icloud.com.cn 端点）
# LOOP_MINUTES=10           # 多久拉一次位置（别太密，怕 Apple 限流）
# STAY_MINUTES=10           # 在一个地方停多久算"到了"
# OUTSIDE_CHECKIN_MINUTES=75 # 在外面每隔多久让 el 看一眼
# PLACE_RADIUS_M=200        # 判"还在同一个地方"的半径
# GOOD_ACCURACY_M=200       # 定位精度好于此米数才说得具体，否则只说大概区域
