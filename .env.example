# ─────────────────────────────────────────────────────────────
# el-system 环境变量
# 复制本文件为 .env.local（本地）或在 Vercel 项目设置里逐项配置。
# 不要把真实的 key 提交进仓库。
# ─────────────────────────────────────────────────────────────

# Claude API 中转站的 key（用于 /api/chat）
CLAUDE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude API 中转站的 base URL（用于 /api/chat）
# 中转站地址，结尾的 /v1 会被自动处理，留着或去掉都行。
CLAUDE_BASE_URL=https://jeniya.chat/v1

# Notion 集成 token（用于 /api/status）
# 在 https://www.notion.so/my-integrations 创建 internal integration 获取，形如 ntn_xxx / secret_xxx
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 状态数据库 ID（用于 /api/status）
# /api/status 会读取这个数据库里最新一条记录的 心情 / 在听什么歌 / 天气。
# 从数据库页面的 URL 里取那段 32 位的 ID。
NOTION_DATABASE_ID=00000000000000000000000000000000
